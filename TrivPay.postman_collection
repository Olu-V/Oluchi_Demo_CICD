              "listen": "test",
              "script": {
                "exec": [
                  "function parseJsonSafe() {\r",
                  "    try { return pm.response.json(); } catch (e) { return null; }\r",
                  "}\r",
                  "\r",
                  "function assertStatusOneOf(codes) {\r",
                  "    pm.test(`Status is one of: ${codes.join(', ')}`, function () {\r",
                  "        pm.expect(codes).to.include(pm.response.code);\r",
                  "    });\r",
                  "}\r",
                  "\r",
                  "function assertResponseTime(maxMs = 5000) {\r",
                  "    pm.test(`Response time is below ${maxMs}ms`, function () {\r",
                  "        pm.expect(pm.response.responseTime).to.be.below(maxMs);\r",
                  "    });\r",
                  "}\r",
                  "\r",
                  "function assertJsonContentIfPresent() {\r",
                  "    const header = pm.response.headers.get('Content-Type') || '';\r",
                  "    if (header) {\r",
                  "        pm.test('Content-Type is JSON when body is JSON', function () {\r",
                  "            pm.expect(header.toLowerCase()).to.include('application/json');\r",
                  "        });\r",
                  "    }\r",
                  "}\r",
                  "\r",
                  "function assertCommonEnvelope(res) {\r",
                  "    pm.test('Response body is valid JSON object', function () {\r",
                  "        pm.expect(res).to.be.an('object');\r",
                  "    });\r",
                  "\r",
                  "    pm.test('Response contains common API envelope field', function () {\r",
                  "        const hasEnvelope = ['message', 'status', 'success', 'data', 'errors']\r",
                  "            .some(key => Object.prototype.hasOwnProperty.call(res, key));\r",
                  "        pm.expect(hasEnvelope).to.equal(true);\r",
                  "    });\r",
                  "}\r",
                  "\r",
                  "function assertMessageIfPresent() {\r",
                  "    const res = parseJsonSafe();\r",
                  "    if (!res) return;\r",
                  "    if (res.message !== undefined) {\r",
                  "        pm.test('message is a valid message field', function () {\r",
