          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const prefixes = [\r",
                  "    \"703\", \"704\", \"705\", \"706\", \"707\", \"708\", \"709\",\r",
                  "    \"803\", \"805\", \"806\", \"807\", \"808\", \"809\",\r",
                  "    \"810\", \"811\", \"812\", \"813\", \"814\", \"815\", \"816\", \"817\", \"818\", \"819\",\r",
                  "    \"901\", \"902\", \"903\", \"904\", \"905\", \"906\", \"907\", \"908\", \"909\",\r",
                  "    \"912\", \"913\", \"914\", \"915\", \"916\"\r",
                  "];\r",
                  "\r",
                  "const prefix = prefixes[Math.floor(Math.random() * prefixes.length)];\r",
                  "const lineNumber = Math.floor(1000000 + Math.random() * 9000000);\r",
                  "\r",
                  "const phoneNumber = `+234${prefix}${lineNumber}`;\r",
                  "\r",
                  "pm.environment.set(\"phone_number\", phoneNumber);\r",
                  "console.log(phoneNumber);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const statusCode = pm.response.code;",
                  "const contentType = (pm.response.headers.get('Content-Type') || '').toLowerCase();",
                  "const hasJsonContentType = contentType.includes('application/json');",
                  "let jsonData = null;",
                  "let parseError = null;",
                  "",
                  "try {",
                  "    if (hasJsonContentType || pm.response.text()) {",
                  "        jsonData = pm.response.json();",
                  "        console.log('Response JSON:', JSON.stringify(jsonData));",
                  "    }",
                  "} catch (err) {",
                  "    parseError = err;",
                  "}",
                  "",
                  "function getRequestJsonBody() {",
                  "    const body = pm.request && pm.request.body;",
                  "    if (!body) return null;",
                  "",
                  "    if (body.mode === 'raw') {",
                  "        try {",
                  "            return JSON.parse(pm.variables.replaceIn(body.raw || ''));",
                  "        } catch (e) {",
                  "            return null;",
                  "        }",
                  "    }",
                  "",
                  "    if (body.mode === 'urlencoded') {",
                  "        return (body.urlencoded?.members || []).reduce((acc, item) => {",
                  "            if (!item.disabled) {",
                  "                acc[item.key] = pm.variables.replaceIn(String(item.value || ''));",
                  "            }",
                  "            return acc;",
                  "        }, {});",
                  "    }",
                  "",
                  "    if (body.mode === 'formdata') {",
                  "        return (body.formdata?.members || []).reduce((acc, item) => {",
                  "            if (!item.disabled && item.type !== 'file') {",
                  "                acc[item.key] = pm.variables.replaceIn(String(item.value || ''));",
                  "            }",
                  "            return acc;",
                  "        }, {});",
                  "    }",
                  "",
                  "    return null;",
                  "}",
                  "",
                  "function firstDefined(values) {",
                  "    return values.find(value => value !== undefined && value !== null && String(value).trim() !== '');",
                  "}",
                  "",
                  "function persistVar(key, value) {",
                  "    if (value === undefined || value === null || String(value).trim() === '') return;",
                  "    const normalized = String(value).trim();",
                  "    pm.environment.set(key, normalized);",
                  "    pm.collectionVariables.set(key, normalized);",
                  "    console.log(`✅ Persisted ${key}:`, normalized);",
                  "}",
                  "",
                  "const requestBodyData = getRequestJsonBody();",
                  "",
                  "const requestPhone = firstDefined([",
                  "    requestBodyData && requestBodyData.phone_number,",
                  "    requestBodyData && requestBodyData.phone,",
                  "    requestBodyData && requestBodyData.mobile,",
                  "    pm.environment.get('phone_number'),",
                  "    pm.collectionVariables.get('phone_number')",
                  "]);",
                  "",
                  "if (requestPhone) {",
                  "    persistVar('phone_number', requestPhone);",
                  "} else {",
                  "    console.warn('⚠️ No phone_number found in request body or existing variables');",
                  "}",
                  "",
                  "const requestEmail = firstDefined([",
                  "    requestBodyData && requestBodyData.email,",
                  "    pm.environment.get('email'),",
                  "    pm.collectionVariables.get('email')",
                  "]);",
                  "",
                  "if (requestEmail) {",
                  "    persistVar('email', requestEmail);",
                  "}",
                  "",
                  "const responseUserId = firstDefined([",
                  "    jsonData && jsonData.user && jsonData.user.id,",
                  "    jsonData && jsonData.user && jsonData.user.user_id,",
                  "    jsonData && jsonData.data && jsonData.data.user && jsonData.data.user.id,",
                  "    jsonData && jsonData.data && jsonData.data.user && jsonData.data.user.user_id,",
                  "    jsonData && jsonData.data && jsonData.data.id,",
                  "    jsonData && jsonData.data && jsonData.data.user_id,",
                  "    jsonData && jsonData.id,",
                  "    jsonData && jsonData.user_id,",
                  "    pm.environment.get('userId'),",
                  "    pm.collectionVariables.get('userId')",
                  "]);",
                  "",
                  "if (responseUserId) {",
                  "    persistVar('userId', responseUserId);",
                  "}",
                  "",
                  "const responseOtp = firstDefined([",
                  "    jsonData && jsonData.otp,",
                  "    jsonData && jsonData.code,",
                  "    jsonData && jsonData.data && jsonData.data.otp,",
                  "    jsonData && jsonData.data && jsonData.data.code,",
                  "    jsonData && jsonData.message && jsonData.message.otp,",
                  "    jsonData && jsonData.message && jsonData.message.data && jsonData.message.data.otp,",
                  "    jsonData && jsonData.verification_code",
                  "]);",
                  "",
                  "if (responseOtp) {",
                  "    persistVar('otp', responseOtp);",
                  "    persistVar('otp_source', 'response');",
                  "} else {",
                  "    console.warn('⚠️ No OTP found in response; keeping any previously stored OTP unchanged');",
                  "}",
                  "",
                  "pm.test('Response time is under 10 seconds', () => {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});",
                  "",
                  "pm.test('Status code is a supported register outcome', () => {",
                  "    pm.expect(statusCode).to.be.oneOf([201]);",
                  "});",
                  "",
                  "pm.test('Phone number tracked in environment and collection', () => {",
                  "    if ([200, 201, 202].includes(statusCode)) {",
                  "        const envPhone = pm.environment.get('phone_number');",
                  "        const colPhone = pm.collectionVariables.get('phone_number');",
                  "        pm.expect(envPhone, 'environment phone_number must be saved').to.be.a('string').and.not.empty;",
                  "        pm.expect(colPhone, 'collection phone_number must be saved').to.be.a('string').and.not.empty;",
                  "        pm.expect(envPhone).to.eql(colPhone);",
                  "    }",
                  "});",
                  "",
                  "pm.test('OTP tracked in environment and collection when returned', () => {",
                  "    if ([200, 201, 202].includes(statusCode) && responseOtp) {",
                  "        const envOtp = pm.environment.get('otp');",
                  "        const colOtp = pm.collectionVariables.get('otp');",
                  "        pm.expect(envOtp, 'environment otp must be saved').to.be.a('string').and.not.empty;",
                  "        pm.expect(colOtp, 'collection otp must be saved').to.be.a('string').and.not.empty;",
                  "        pm.expect(envOtp).to.eql(colOtp);",
                  "    }",
                  "});",
                  "",
                  "pm.test('Response body is valid JSON when body is present', () => {",
                  "    if (pm.response.text()) {",
                  "        pm.expect(parseError, parseError && parseError.message).to.equal(null);",
                  "        pm.expect(jsonData).to.be.an('object');",
                  "    }",
                  "});",
                  "",
                  "pm.test('Successful registration returns expected shape', () => {",
                  "    if ([200, 201, 202].includes(statusCode)) {",
                  "        pm.expect(jsonData).to.be.an('object');",
                  "        pm.expect(jsonData).to.have.property('message');",
                  "",
                  "        if (jsonData.data !== undefined && jsonData.data !== null) {",
                  "            pm.expect(jsonData.data).to.be.an('string');",
                  "            ['id', 'user_id', 'email', 'phone_number'].forEach(field => {",
                  "                if (jsonData.data[field] !== undefined && jsonData.data[field] !== null) {",
                  "                    pm.expect(jsonData.data[field]).to.not.eql('');",
                  "                }",
                  "            });",
                  "        }",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
